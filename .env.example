# ============================================
# GENEROS CRM - Environment Variables
# ============================================

# --- Server ---
PORT=3000
NODE_ENV=production

# --- Database (Railway auto-injects DATABASE_URL when you add Postgres plugin) ---
# Railway provides this automatically. For local dev, set manually:
DATABASE_URL=postgresql://user:password@localhost:5432/generos_crm

# --- Auth ---
JWT_SECRET=change_this_to_a_long_random_string_min_32_chars
JWT_EXPIRY=8h

# --- Deepseek AI ---
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_API_URL=https://api.deepseek.com/v1/chat/completions
DEEPSEEK_MODEL=deepseek-chat

# --- Business Rules ---
MAX_DISCOUNT_PCT=50
MIN_COHORT_SIZE_ANALYSIS=100
CHURN_THRESHOLD_DAYS=90

# --- RFM Thresholds (calibrate to your business!) ---
# Recency: days since last purchase for scores 1,2,3,4 (5 is anything beyond)
RFM_RECENCY_DAYS=15,30,60,90
# Frequency: min purchase count for scores 1,2,3,4
RFM_FREQUENCY=5,3,2,1
# Monetary: total spend (IDR) for scores 1,2,3,4 — ADJUST to your price points
RFM_MONETARY=2000000,1000000,500000,150000

# --- Batch Job Auth (for external cron trigger) ---
# External scheduler (GitHub Actions / cron-job.org) hits /api/jobs/* with this key
JOB_SECRET_KEY=change_this_to_another_long_random_string

# --- CORS ---
# Frontend URL (set to your deployed frontend domain)
ALLOWED_ORIGIN=http://localhost:5173
